{
  "JwtSettings": {
    "SecretKey": "YOUR_DEV_JWT_SECRET_KEY_GOES_HERE",
    "Issuer": "StudifyAPI",
    "Audience": "StudifyUsers",
    "ExpiryInMinutes": 15,
    "RefreshTokenExpiryInDays": 7
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=StudifyDb;User=root;Password=YOUR_LOCAL_DB_PASSWORD;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
